{
  "name": "project-relay-backend",
  "version": "1.0.0",
  "description": "Project Relay backend",
  "main": "src/server.js",
  "scripts": {
    "dev": "nodemon src/server.js",
    "start": "node src/server.js",
    "start:prod": "prisma migrate deploy && node src/server.js",
    "lint": "node --check src/server.js && node --check src/app.js && node --check src/routes/auth.routes.js && node --check src/routes/users.routes.js && node --check src/routes/chat.routes.js && node --check src/socket/index.js",
    "test": "node --test tests/**/*.test.js",
    "postinstall": "prisma generate",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio"
  },
  "dependencies": {
    "@prisma/client": "^6.19.2",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.21.2",
    "express-rate-limit": "^8.3.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "next": "^15.2.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "socket.io": "^4.8.1"
  },
  "devDependencies": {
    "nodemon": "^3.1.10",
    "prisma": "^6.19.2",
    "supertest": "^7.1.4"
  }
}
